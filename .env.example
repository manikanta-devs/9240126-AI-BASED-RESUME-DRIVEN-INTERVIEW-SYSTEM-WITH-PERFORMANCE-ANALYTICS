# Environment Configuration Template
# Copy this file to .env and fill in your values. Never commit real secrets.

# ==========================================
# Flask / deployment
# ==========================================
FLASK_ENV=development
DEBUG=false
PORT=5000
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_ENABLED=false

# Destructive/demo endpoints are disabled unless explicitly enabled.
# Keep false for production.
ENABLE_DEVELOPER_TOOLS=false

# ==========================================
# Frontend
# ==========================================
VITE_API_BASE_URL=http://localhost:5000
VITE_ENABLE_DEV_TOOLS=false

# ==========================================
# Free / low-cost AI provider fallback chain
# Configure one or more. The app rotates through available providers.
# ==========================================
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
GEMINI_API_KEY=

# Optional additional keys for rotation, e.g.
# GROQ_API_KEY_2=
# MISTRAL_API_KEY_2=